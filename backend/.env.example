PORT=5000
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Local:
MONGODB_URI=mongodb://127.0.0.1:27017/priceiq
# Atlas (production — uncomment and fill):
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/priceiq?retryWrites=true&w=majority

# ── Redis — Upstash (TLS, rediss://) ─────────────────────────────────────────
REDIS_URL=rediss://default:<password>@<host>.upstash.io:6379
# Local Redis (no TLS):
# REDIS_URL=redis://localhost:6379

# ── Marketplace APIs (RapidAPI) ───────────────────────────────────────────────
# Amazon Real-Time Data API (real-time-amazon-data.p.rapidapi.com)
RAPIDAPI_KEY=your_rapidapi_key_here

# Flipkart Real-Time Data API (real-time-flipkart-data2.p.rapidapi.com)
# Uses the same RapidAPI account key as Amazon
FLIPKART_RAPIDAPI_KEY=your_rapidapi_key_here

# ── CORS & Frontend ───────────────────────────────────────────────────────────
# Set to your Vercel production URL in production
FRONTEND_URL=http://localhost:5173
# Multiple origins: CORS_ORIGIN=http://localhost:5173,https://priceiq.vercel.app

# ── Optional AI Keys ──────────────────────────────────────────────────────────
GROQ_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
